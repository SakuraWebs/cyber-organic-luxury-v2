# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_CONTACT_EMAIL: The email address where contact form submissions are sent.
VITE_CONTACT_EMAIL="info@cyberorganicagency.com"

# STRIPE CONFIGURATION
# Set these inside AI Studio -> Settings -> Environment Variables
STRIPE_SECRET_KEY="sk_test_..."
VITE_STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# EMAIL CONFIGURATION (ZOHO)
# Set these inside AI Studio -> Settings -> Environment Variables
# Use Zoho App Password if 2FA is enabled
ZOHO_USER="info@cyberorganicagency.com"
ZOHO_USER_CyberOrganic="info@cyberorganicagency.com"
ZOHO_PASS="YOUR_ZOHO_PASS"

